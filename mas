<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>MAS Bookshelf</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Lora:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap" rel="stylesheet">
<style>
/* ── RESET & BASE SYSTEM ── */
*, *::before, *::after { 
  margin: 0; 
  padding: 0; 
  box-sizing: border-box; 
  -webkit-tap-highlight-color: transparent; 
}

:root {
  --bg-dark: #000000; /* Nền tối tuyệt đối */
  --bg-card: rgba(20, 20, 25, 0.6);
  --border-light: rgba(255, 255, 255, 0.08);
  --text-primary: #f4f4f5;
  --text-muted: #a1a1aa;
  --blue-accent: #007aff; /* Điểm nhấn xanh dương công nghệ */
  --blue-glow: rgba(0, 122, 255, 0.35);
  --space-purple: #101432;
  --lora-font: 'Lora', Georgia, serif;
  --inter-font: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --safe-top: env(safe-area-inset-top, 0px);
}

html, body { 
  height: 100%; 
  background-color: #000; 
  font-family: var(--inter-font);
  color: var(--text-primary);
  overflow: hidden;
}

#app {
  position: relative;
  width: 100%;
  max-width: 430px;
  height: 100%;
  margin: 0 auto;
  background-color: var(--bg-dark);
  overflow: hidden;
  box-shadow: 0 0 50px rgba(0, 0, 0, 0.9);
  display: flex;
  flex-direction: column;
}

/* ── AMBIENT GLOW ORBS ── */
.glow-bg {
  position: absolute;
  width: 280px;
  height: 280px;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  pointer-events: none;
  z-index: 1;
}
.glow-1 {
  background: var(--blue-accent);
  top: -30px;
  left: -50px;
}
.glow-2 {
  background: #00f2fe;
  bottom: 120px;
  right: -50px;
}
.glow-3 {
  background: #0d1117;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 220px;
  height: 220px;
  opacity: 0.1;
}

/* ── SPA VIEWPORT SYSTEM ── */
.page {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(35px);
  -webkit-backdrop-filter: blur(35px);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: none;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s, scale 0.4s, visibility 0.4s;
  z-index: 10;
  visibility: hidden;
  opacity: 0;
}
.page::-webkit-scrollbar { display: none; }

/* States */
.page.p-active {
  visibility: visible;
  opacity: 1;
  transform: translate3d(0, 0, 0) scale(1);
}
.page.p-hidden {
  transform: translate3d(100%, 0, 0);
  opacity: 0;
  pointer-events: none;
  visibility: hidden;
}
.page.p-pushed {
  transform: translate3d(-10%, 0, 0) scale(0.96);
  opacity: 0.45;
  pointer-events: none;
  visibility: visible;
}

.header-spacing { height: calc(16px + var(--safe-top)); min-height: 50px; flex-shrink: 0; }
.bottom-spacing { height: calc(150px + var(--safe-bottom)); flex-shrink: 0; }

/* ── HOME PAGE ── */
.home-header { 
  padding: 10px 20px 14px; 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
}
.home-title {
  font-family: var(--lora-font);
  font-weight: 800;
  font-size: 34px;
  letter-spacing: -0.8px;
  background: linear-gradient(135deg, #ffffff 60%, #a1a1aa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.htools { display: flex; align-items: center; gap: 12px; }

/* Progress Ring */
.score-ring {
  width: 44px; height: 44px;
  border-radius: 50%; background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.score-ring svg {
  position: absolute; inset: 0;
  transform: rotate(-90deg); width: 100%; height: 100%;
}
.score-ring .nums { display: flex; flex-direction: column; align-items: center; line-height: 1.1; z-index: 2; }
.score-ring .big { font-size: 13px; font-weight: 700; color: #fff; }
.score-ring .sm { font-size: 8px; font-weight: 600; color: var(--text-muted); }

.avatar {
  width: 42px; height: 42px; border-radius: 50%; background: rgba(255, 255, 255, 0.05);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
  border: 1.5px solid rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.avatar svg { width: 24px; height: 24px; fill: #ffffff; opacity: 0.9; }

/* Search Bar */
.sbar-wrap { padding: 0 16px 14px; }
.sbar {
  display: flex; align-items: center; gap: 10px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 14px;
  padding: 10px 14px; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  box-shadow: inset 0 1px 1px rgba(255,255,255,0.02), 0 4px 12px rgba(0,0,0,0.5);
}
.sbar:focus-within {
  border-color: rgba(0, 122, 255, 0.4);
  background: rgba(255, 255, 255, 0.07);
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05), 0 0 16px rgba(0, 122, 255, 0.15);
}
.sbar svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--text-muted); }
.sbar input {
  flex: 1; min-width: 0; background: none; border: none; outline: none;
  font-family: var(--inter-font); font-size: 15px; color: #fff;
}
.sbar input::placeholder { color: rgba(255, 255, 255, 0.3); }
.sbar-x {
  background: rgba(255, 255, 255, 0.12); border: none; color: #fff;
  width: 18px; height: 18px; border-radius: 50%; font-size: 9px;
  cursor: pointer; display: none; align-items: center; justify-content: center;
}

.sec-title {
  font-family: var(--lora-font); font-weight: 800; font-size: 24px;
  letter-spacing: -0.3px; padding: 12px 20px 10px;
}
.sec-row { display: flex; justify-content: space-between; align-items: baseline; padding: 16px 20px 10px; }
.sec-row .sec-title { padding: 0; }
.see-all { font-size: 14px; color: var(--blue-accent); font-weight: 600; cursor: pointer; }

/* Category Cards */
.cat-card {
  margin: 0 16px 16px; height: 200px; border-radius: 20px;
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.02), 0 8px 24px rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
  overflow: hidden; position: relative; display: flex; align-items: center;
  cursor: pointer; transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.25s, background 0.25s;
}
.cat-card:active { transform: scale(0.98); }
.cat-card:hover {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.12);
}

.cat-label {
  font-family: var(--lora-font); font-weight: 800; font-size: 24px;
  line-height: 1.25; letter-spacing: -0.4px; padding-left: 24px;
  width: 160px; flex-shrink: 0; z-index: 5;
  text-shadow: 0 2px 10px rgba(0,0,0,0.8);
}

.bk-stack { position: absolute; right: -15px; top: 50%; transform: translateY(-50%); display: flex; height: 180px; }
.bk {
  width: 106px; height: 180px; margin-left: -35px; border-radius: 4px 12px 12px 4px;
  box-shadow: -8px 0 20px rgba(0,0,0,0.6); overflow: hidden; flex-shrink: 0;
  display: flex; flex-direction: column; padding: 14px 12px; border-left: 3.5px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
}
.bk-t { font-family: var(--lora-font); font-weight: 800; font-size: 14px; line-height: 1.2; text-shadow: 0 1px 4px rgba(0,0,0,0.4); }
.bk-a { font-size: 10px; font-weight: 500; margin-top: 4px; opacity: 0.8; }

/* Book Covers colors */
.b1 { background: linear-gradient(135deg, rgba(0, 122, 255, 0.2) 0%, rgba(0, 122, 255, 0.4) 100%); color: #fff; border: 1px solid rgba(0, 122, 255, 0.25); }
.b2 { background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.03) 100%); color: #fff; border: 1px solid rgba(255, 255, 255, 0.12); }
.b3 { background: linear-gradient(135deg, rgba(52, 152, 219, 0.2) 0%, rgba(41, 128, 185, 0.4) 100%); color: #fff; border: 1px solid rgba(52, 152, 219, 0.25); }
.b4 { background: linear-gradient(135deg, rgba(44, 62, 80, 0.4) 0%, rgba(52, 73, 94, 0.4) 100%); color: #fff; border: 1px solid rgba(255, 255, 255, 0.1); }
.b5 { background: linear-gradient(135deg, rgba(39, 39, 42, 0.3) 0%, rgba(9, 9, 11, 0.5) 100%); color: #f4f4f5; border: 1px solid rgba(255,255,255,0.08); }
.b6 { background: linear-gradient(135deg, rgba(142, 68, 173, 0.2) 0%, rgba(155, 89, 182, 0.4) 100%); color: #fff; border: 1px solid rgba(142, 68, 173, 0.25); }

/* Bestsellers */
.scroll-row { display: flex; gap: 12px; padding: 0 16px 12px; overflow-x: auto; scrollbar-width: none; }
.scroll-row::-webkit-scrollbar { display: none; }
.shelf-c {
  flex-shrink: 0; width: 135px; height: 190px; border-radius: 14px;
  overflow: hidden; cursor: pointer; box-shadow: 0 8px 16px rgba(0,0,0,0.5);
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1); display: flex; flex-direction: column; padding: 16px 14px;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
}
.shelf-c:active { transform: scale(0.96); }
.shelf-c .sc-t { font-family: var(--lora-font); font-weight: 800; font-size: 18px; line-height: 1.2; text-shadow: 0 1px 4px rgba(0,0,0,0.5); }
.shelf-c .sc-a { font-size: 11px; font-weight: 500; margin-top: 6px; opacity: 0.8; }

.sc1 { background: linear-gradient(135deg, rgba(0, 122, 255, 0.2) 0%, rgba(0, 122, 255, 0.4) 100%); color: #fff; border: 1px solid rgba(0, 122, 255, 0.25); }
.sc2 { background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.03) 100%); color: #fff; border: 1px solid rgba(255, 255, 255, 0.12); }
.sc3 { background: linear-gradient(135deg, rgba(52, 152, 219, 0.2) 0%, rgba(41, 128, 185, 0.4) 100%); color: #fff; border: 1px solid rgba(52, 152, 219, 0.25); }
.peek { width: 24px; flex-shrink: 0; opacity: 0.15; background: rgba(255, 255, 255, 0.05); border-radius: 12px; }

/* Search Results */
#home-results { display: none; background: transparent; min-height: 200px; }
#home-results.on { display: block; }
#home-main.off { display: none; }
.res-count { font-size: 13px; color: var(--text-muted); padding: 8px 20px; }
.res-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.05); cursor: pointer;
  background: rgba(255,255,255,0.01);
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.res-item:active { background: rgba(255,255,255,0.04); }
.res-item .rname { font-size: 15px; font-weight: 500; line-height: 1.4; color: #fff; }
.res-item .rchev { color: var(--text-muted); font-size: 18px; }

/* Empty state */
.empty-st { text-align: center; padding: 60px 20px; }
.empty-st .ei { font-size: 40px; margin-bottom: 12px; }
.empty-st .et { font-family: var(--lora-font); font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 6px; }
.empty-st .es { font-size: 14px; color: var(--text-muted); }

/* ── SPACES PAGE ── */
.space-header {
  padding: 20px 20px 10px;
}
.space-header h1 {
  font-family: var(--inter-font);
  font-weight: 800;
  font-size: 30px;
  letter-spacing: -0.5px;
  color: #fff;
}
.space-header p {
  font-size: 14px;
  color: var(--text-muted);
  margin-top: 4px;
  font-weight: 500;
}

/* Audio Space Card */
.space-card {
  margin: 16px;
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.15) 0%, rgba(0, 122, 255, 0.3) 100%);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 122, 255, 0.25);
  border-radius: 22px;
  padding: 24px;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 1px 1px rgba(255,255,255,0.1), 0 12px 32px rgba(0, 122, 255, 0.15);
  cursor: pointer;
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.space-card:active { transform: scale(0.98); }

.space-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}
.live-badge {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(0, 0, 0, 0.5);
  padding: 6px 12px;
  border-radius: 10px;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.5px;
  border: 1px solid rgba(255, 255, 255, 0.08);
}
.live-pulse {
  width: 7px;
  height: 7px;
  background-color: #ff3b30;
  border-radius: 50%;
  animation: pulse-glow 1.4s infinite;
}
@keyframes pulse-glow {
  0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7); }
  70% { transform: scale(1); box-shadow: 0 0 0 5px rgba(255, 59, 48, 0); }
  100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); }
}

.more-btn {
  color: #fff;
  opacity: 0.85;
  font-size: 20px;
  font-weight: bold;
}

.space-title {
  font-size: 28px;
  font-weight: 800;
  line-height: 1.25;
  color: #fff;
  margin-bottom: 22px;
  text-shadow: 0 2px 10px rgba(0,0,0,0.5);
}

.listeners-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 24px;
}
.listeners-avatars {
  display: flex;
  align-items: center;
}
.listeners-avatars .mini-av {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 1.5px solid rgba(0, 122, 255, 0.4);
  background: #fff;
  margin-right: -8px;
  object-fit: cover;
}
.listeners-count {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  opacity: 0.9;
}

/* Host Info */
.host-section {
  display: flex;
  align-items: center;
  gap: 10px;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: 18px;
  margin-bottom: 12px;
}
.host-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  object-fit: cover;
  border: 1px solid rgba(255,255,255,0.2);
}
.host-name-wrap {
  display: flex;
  align-items: center;
  gap: 4px;
}
.host-name {
  font-size: 14px;
  font-weight: 700;
  color: #fff;
}
.verified-icon {
  width: 15px;
  height: 15px;
  fill: var(--blue-accent);
}
.host-badge {
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 6px;
}

.status-text {
  font-size: 14px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
}

/* ── PERSISTENT GLOBAL AUDIO PLAYER ── */
.audio-wave-container {
  position: absolute;
  bottom: calc(85px + var(--safe-bottom));
  left: 16px;
  right: 16px;
  background: rgba(10, 10, 12, 0.85);
  border: 1px solid rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border-radius: 18px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7), inset 0 1px 0 rgba(255,255,255,0.05);
  z-index: 99;
  transform: translateY(15px);
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.audio-wave-container.on {
  transform: translateY(0);
  opacity: 1;
  pointer-events: all;
}
.player-info {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}
.p-control-btn {
  background: var(--blue-accent);
  border: none;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  cursor: pointer;
  flex-shrink: 0;
}
.player-text-meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.player-title-str {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.player-subtitle-str {
  font-size: 11px;
  color: var(--text-muted);
}
.wave-bars {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 20px;
}
.wave-bar {
  width: 3px;
  height: 4px;
  background-color: var(--blue-accent);
  border-radius: 2px;
}
.wave-bars.active .wave-bar {
  animation: wave-motion 1.2s ease-in-out infinite alternate;
}
.wave-bars.active .wave-bar:nth-child(2) { animation-delay: 0.15s; height: 18px; }
.wave-bars.active .wave-bar:nth-child(3) { animation-delay: 0.3s; height: 10px; }
.wave-bars.active .wave-bar:nth-child(4) { animation-delay: 0.45s; height: 16px; }
.wave-bars.active .wave-bar:nth-child(5) { animation-delay: 0.6s; height: 12px; }

@keyframes wave-motion {
  0% { height: 4px; }
  100% { height: 20px; }
}

/* ── ALBUM PAGE ── */
.alb-back {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 15px; font-weight: 600; color: var(--blue-accent);
  padding: 16px 20px 8px; cursor: pointer; user-select: none;
}
.alb-back svg { width: 8px; height: 14px; }
.alb-hero { padding: 12px 20px 16px; }
.alb-hero h1 {
  font-family: var(--lora-font); font-weight: 800; font-size: 32px;
  letter-spacing: -0.5px; line-height: 1.2;
}
.alb-hero .alb-sub { font-size: 14px; color: var(--text-muted); margin-top: 6px; }

/* Grid book categories */
.books-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 4px 16px 16px; }
.bcard {
  border-radius: 16px; cursor: pointer; min-height: 150px;
  display: flex; flex-direction: column; justify-content: space-between;
  padding: 16px 14px; 
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  box-shadow: inset 0 1px 1px rgba(255,255,255,0.02), 0 4px 16px rgba(0,0,0,0.3);
  position: relative; transition: transform 0.18s, border-color 0.18s, background-color 0.18s;
}
.bcard:active { transform: scale(0.96); }
.bcard:hover {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.1);
}

.bcard-num { font-size: 11px; font-weight: 700; opacity: 0.25; letter-spacing: 0.5px; }
.bcard-title {
  font-family: var(--lora-font); font-weight: 700; font-size: 15px;
  line-height: 1.35; color: #fff; margin: 10px 0;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
.bcard-badge {
  align-self: flex-start; background: rgba(0, 122, 255, 0.1);
  color: var(--blue-accent); font-size: 11px; font-weight: 700;
  padding: 4px 10px; border-radius: 8px; border: 0.5px solid rgba(0, 122, 255, 0.25);
}
.bcard-badge.empty {
  background: rgba(255, 255, 255, 0.04); color: var(--text-muted);
  border-color: transparent;
}

/* ── BOOK READER ── */
.reader-controls-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.01);
  backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
}
.reader-title-short {
  font-family: var(--lora-font);
  font-weight: 700;
  font-size: 14px;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180px;
}
.font-controls {
  display: flex;
  align-items: center;
  gap: 12px;
}
.font-btn {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #fff;
  width: 32px;
  height: 32px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
}
.font-btn:active { background: rgba(255, 255, 255, 0.1); }

/* Custom Chapter Selection styling */
.chapter-nav-bar {
  padding: 12px 16px;
  background: rgba(255, 255, 255, 0.01);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.chapter-select-wrapper {
  position: relative;
  width: 100%;
}
.chapter-select-wrapper::after {
  content: '▼';
  font-size: 9px;
  color: var(--text-muted);
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  position: absolute;
  pointer-events: none;
}
.chapter-select {
  appearance: none;
  -webkit-appearance: none;
  width: 100%;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  color: #fff;
  padding: 10px 32px 10px 14px;
  border-radius: 12px;
  font-family: var(--inter-font);
  font-size: 13px;
  font-weight: 600;
  outline: none;
  cursor: pointer;
  transition: all 0.25s ease;
}
.chapter-select:focus {
  border-color: var(--blue-accent);
  background: rgba(255, 255, 255, 0.05);
  box-shadow: 0 0 12px var(--blue-glow);
}

/* Reader Body */
.reader-body {
  flex: 1;
  overflow-y: auto;
  padding: 24px 20px;
  font-family: var(--lora-font);
  line-height: 1.8;
  color: #e4e4e7;
  font-size: 16px; 
  background: rgba(0, 0, 0, 0.5);
}
.reader-body h4 {
  font-family: var(--inter-font);
  color: #fff;
  font-size: 1.15em;
  font-weight: 800;
  margin-top: 24px;
  margin-bottom: 12px;
  line-height: 1.35;
}
.reader-body p {
  margin-bottom: 16px;
  text-align: justify;
}

/* ── GLOBAL TAB BAR ── */
.tabbar-outer {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 10px 16px calc(10px + var(--safe-bottom));
  z-index: 90;
  pointer-events: none;
  display: flex;
  align-items: flex-end;
  gap: 10px;
}
.tabbar {
  flex: 1; display: flex; justify-content: space-around; align-items: center;
  height: 60px; border-radius: 30px; position: relative;
  background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%);
  -webkit-backdrop-filter: blur(30px) saturate(180%); backdrop-filter: blur(30px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.1); 
  box-shadow: inset 0 1px 1px rgba(255,255,255,0.1), 0 12px 36px rgba(0,0,0,0.8);
  pointer-events: all;
}
.tab {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.4);
  cursor: pointer; padding: 8px 12px; position: relative;
}
.tab.on { color: var(--blue-accent); }
.tab.on::after {
  content: ''; position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
  width: 24px; height: 3px; border-radius: 0 0 3px 3px;
  background: var(--blue-accent); box-shadow: 0 0 8px var(--blue-accent);
}
.tab svg { width: 22px; height: 22px; }

.fab {
  width: 60px; height: 60px; border-radius: 50%; flex-shrink: 0;
  background: linear-gradient(135deg, rgba(0, 122, 255, 0.8), rgba(0, 80, 200, 0.9));
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.25); display: flex; align-items: center; justify-content: center;
  cursor: pointer; pointer-events: all; 
  box-shadow: inset 0 1px 1px rgba(255,255,255,0.2), 0 10px 24px rgba(0,122,255,0.3);
  transition: transform 0.15s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.15s;
}
.fab:active { transform: scale(0.92); }
.fab svg { width: 22px; height: 22px; stroke: #ffffff; }

/* TOAST NOTIFICATION */
.toast {
  position: absolute; bottom: calc(145px + var(--safe-bottom)); left: 0; right: 0;
  display: flex; justify-content: center; z-index: 500; pointer-events: none;
