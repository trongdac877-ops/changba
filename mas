// ─── ĐIỀU HƯỚNG TAB ───
function switchTab(tabId) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('on'));
  document.getElementById(`tab-${tabId}`).classList.add('on');

  document.querySelectorAll('.page').forEach(p => {
    p.classList.remove('p-active', 'p-pushed');
    p.classList.add('p-hidden');
  });

  if (tabId === 'home') {
    document.getElementById('pg-home').className = 'page p-active';
  } else if (tabId === 'spaces') {
    document.getElementById('pg-spaces').className = 'page p-active';
  }
}

function returnToHome() {
  switchTab('home');
}

// ─── ĐIỀU HƯỚNG ALBUM & CHI TIẾT SÁCH ───
function openAlbum() {
  const home = document.getElementById('pg-home');
  const alb  = document.getElementById('pg-album');
  
  home.className = 'page p-pushed';
  alb.className = 'page p-active';
  
  renderAlbum(BOOKS);
}

function closeAlbum() {
  const home = document.getElementById('pg-home');
  const alb  = document.getElementById('pg-album');
  
  alb.className = 'page p-hidden';
  home.className = 'page p-active';
}

function openBook(idx) {
  const b = BOOKS[idx];
  
  if (!b.hasContent) {
    showToast('Cuốn sách này đang được cập nhật nội dung.');
    return;
  }

  const alb = document.getElementById('pg-album');
  const bookView = document.getElementById('pg-book');

  document.getElementById('reader-book-title').textContent = b.t;
  buildChapterSelector();
  loadChapter("1");

  alb.className = 'page p-pushed';
  bookView.className = 'page p-active';
}

function closeBook() {
  const alb = document.getElementById('pg-album');
  const bookView = document.getElementById('pg-book');
  
  bookView.className = 'page p-hidden';
  alb.className = 'page p-active';
}

// ─── TRÌNH ĐỌC SÁCH ───
let currentFontSize = 16;

function adjustFontSize(dir) {
  currentFontSize += dir * 1.5;
  if (currentFontSize < 12) currentFontSize = 12;
  if (currentFontSize > 26) currentFontSize = 26;
  document.getElementById('reader-main-content').style.fontSize = currentFontSize + 'px';
}

function buildChapterSelector() {
  const sel = document.getElementById('chapter-selector');
  sel.innerHTML = '';
  for (let key in PLACEBO_DATA) {
    const opt = document.createElement('option');
    opt.value = key;
    opt.textContent = PLACEBO_DATA[key].chName;
    sel.appendChild(opt);
  }
}

function loadChapter(key) {
  const contentArea = document.getElementById('reader-main-content');
  contentArea.innerHTML = PLACEBO_DATA[key].content;
  document.getElementById('pg-book').scrollTop = 0;
}

// ─── AUDIO SPACES (PHÁT QUAY THỰC TẾ) ───
let isPlayingSpace = false;
const audioPlayer = document.getElementById('real-audio-player');
const globalPlayerContainer = document.getElementById('global-audio-player');
const visualizer = document.getElementById('audio-visualizer-wave');
const playIconSvg = document.getElementById('play-icon-svg');
const statusText = document.getElementById('player-status-str');

function togglePlaySpace() {
  isPlayingSpace = !isPlayingSpace;
  
  if (isPlayingSpace) {
    audioPlayer.play().then(() => {
      globalPlayerContainer.classList.add('on');
      visualizer.classList.add('active');
      playIconSvg.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>`;
      statusText.textContent = "Đang phát trực tiếp";
      showToast('Đang kết nối phòng nói chuyện Giới Thiệu MAS...');
    }).catch(err => {
      console.log("Audio play blocked by browser. User interaction needed first.", err);
      isPlayingSpace = false;
    });
  } else {
    audioPlayer.pause();
    visualizer.classList.remove('active');
    playIconSvg.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>`;
    statusText.textContent = "Đang tạm dừng phát";
    showToast('Đã tạm dừng phát âm thanh.');
  }
}

// ─── RENDER ALBUM GRID ───
function renderAlbum(booksList) {
  const cont = document.getElementById('alb-content');
  
  cont.innerHTML = '<div class="books-grid">' +
    booksList.map((b, localIdx) => {
      const gIdx = BOOKS.findIndex(item => item.t === b.t);
      const num = String(gIdx + 1).padStart(2,'0');
      
      const badge = b.hasContent ? '<span class="bcard-badge">Đọc thử ↗</span>' : '<span class="bcard-badge empty">Chờ dịch</span>';
      
      return `<div class="bcard" onclick="openBook(${gIdx})">
        <div class="bcard-num">${num}</div>
        <div class="bcard-title">${b.t}</div>
        ${badge}
      </div>`;
    }).join('') + '</div>';
}

// ─── TÌM KIẾM ───
const homeQ = document.getElementById('home-q');
const homeX = document.getElementById('home-x');
const homeRes = document.getElementById('home-results');
const homeMn = document.getElementById('home-main');

homeQ.addEventListener('input', () => {
  const q = homeQ.value.trim();
  homeX.style.display = q ? 'flex' : 'none';
  if (!q) {
    homeRes.classList.remove('on');
    homeRes.innerHTML = '';
    homeMn.classList.remove('off');
    return;
  }
  homeMn.classList.add('off');
  homeRes.classList.add('on');
  const n = norm(q);
  const res = BOOKS.filter(b => norm(b.t).includes(n));
  if (!res.length) {
    homeRes.innerHTML = emptyHTML('Không tìm thấy', 'Thử tìm kiếm cuốn sách khác.');
    return;
  }
  homeRes.innerHTML = `<div class="res-count">${res.length} kết quả</div>` +
    res.map(b => {
      const globalIdx = BOOKS.findIndex(item => item.t === b.t);
      return `<div class="res-item" onclick="openBookFromSearch(${globalIdx})">
        <span class="rname">${hl(b.t, q)}</span>
        <span class="rchev">›</span>
      </div>`;
    }).join('');
});

homeX.addEventListener('click', () => {
  homeQ.value = ''; homeX.style.display = 'none';
  homeRes.classList.remove('on'); homeRes.innerHTML = '';
  homeMn.classList.remove('off'); homeQ.blur();
});

function openBookFromSearch(idx) {
  const b = BOOKS[idx];
  if (!b.hasContent) {
    showToast('Cuốn sách này đang được cập nhật nội dung.');
    return;
  }
  openAlbum();
  setTimeout(() => openBook(idx), 200);
}

function focusHomeSearch() {
  switchTab('home');
  homeQ.focus();
}

// ─── HÀM BỔ TRỢ CHUỖI ───
function norm(s) {
  const m = {'à':'a','á':'a','ả':'a','ã':'a','ạ':'a','ă':'a','ắ':'a','ặ':'a','ằ':'a','ẵ':'a','ẳ':'a','â':'a','ấ':'a','ầ':'a','ẩ':'a','ẫ':'a','ậ':'a','đ':'d','è':'e','é':'e','ẻ':'e','ẽ':'e','ẹ':'e','ê':'e','ế':'e','ề':'e','ể':'e','ễ':'e','ệ':'e','ì':'i','í':'i','ỉ':'i','ĩ':'i','ị':'i','ò':'o','ó':'o','ỏ':'o','õ':'o','ọ':'o','ô':'o','ố':'o','ồ':'o','ổ':'o','ỗ':'o','ộ':'o','ơ':'o','ớ':'o','ờ':'o','ở':'o','ỡ':'o','ợ':'o','ù':'u','ú':'u','ủ':'u','ũ':'u','ụ':'u','ư':'u','ứ':'u','ừ':'u','ử':'u','ữ':'u','ự':'u','ỳ':'y','ý':'y','ỷ':'y','ỹ':'y','ỵ':'y'};
  return s.toLowerCase().replace(/./g, c => m[c] || c);
}
function hl(text, q) {
  const tn = norm(text), qn = norm(q);
  const i = tn.indexOf(qn);
  if (i < 0) return text;
  return text.slice(0,i) + '<span style="color:var(--blue-accent);font-weight:600">' + text.slice(i, i+q.length) + '</span>' + text.slice(i+q.length);
}
function emptyHTML(title, sub) {
  return `<div class="empty-st"><div class="ei">🔍</div><div class="et">${title}</div><div class="es">${sub}</div></div>`;
}

// ─── TOAST (THÔNG BÁO) ───
let toastTimer;
function showToast(msg) {
  document.getElementById('toast-msg').textContent = msg;
  const t = document.getElementById('toast');
  t.classList.add('on');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('on'), 2200);
}
</script>
